                    android:id="@+id/voice_start_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create"/>
                <Button
                    android:id="@+id/voice_destroy_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="Destroy"/>
            </LinearLayout>

